/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "ЦФРЯ(F)"
    BEGIN
        MENUITEM "П­Бт...\tCtrl+O(&O)",           ID_FILE_OPEN
        MENUITEM "РњРх\tCtrl+S(&S)",              ID_FILE_SAVE
        MENUITEM "ЗЙРЬОю ЕщПЉПРБт ( BaseEffect ЦїЧд )",  ID_IMPORT_LAYER
        MENUITEM "ЗЙРЬОю ЕщПЉПРБт ( BaseEffect СІПм )",  ID_IMPORT_LAYER_EXCEPT_EFFECT
        MENUITEM SEPARATOR
        MENUITEM "ALL CSV РњРх",                  ID_FILE_ALL_CSVSAVE
        MENUITEM "ALL CSV ЗЮЕх",                  ID_FILE_ALL_CSVLOAD
        MENUITEM "CSV РњРх",                      ID_FILE_CSVSAVE
        MENUITEM "CSV ЗЮЕх",                      ID_FILE_CSVLOAD
        MENUITEM SEPARATOR
        MENUITEM "ГЁГЛБт(&X)",                     ID_APP_EXIT
    END
    POPUP "ИЖПьНК(&M)"
    BEGIN
        MENUITEM "ОјРН(&N)",                      ID_VIEW_CURNONE
        MENUITEM "МБХУ(&C)",                      ID_VIEW_SELECT
        MENUITEM "РЬЕП(&M)",                      ID_VIEW_MOVE
        MENUITEM "ШИРќ(&R)",                      ID_VIEW_ROTATE
        MENUITEM "ХЉБт(&S)",                      ID_VIEW_SCALE
        MENUITEM "ЙкНК ЦэС§(&B)",                   ID_VIEW_BOXEDIT
        MENUITEM "ИїНКФЩСь МБХУ(&K)",                 ID_VIEW_SELECT_MOBSCH
    END
    POPUP "КИБт(&V)"
    BEGIN
        MENUITEM "ЕЕБИ И№РН(&T)",                   ID_VIEW_TOOLBAR
        MENUITEM "ЛѓХТ ЧЅНУСй(&S)",                  ID_VIEW_STATUS_BAR
        MENUITEM "ФГИЏХЭПЁ ФЋИоЖѓ АэСЄ (&H)",            ID_VIEW_CAMERA_CHAR
        MENUITEM "СіСЄ РЇФЁЗЮ ФГИЏХЭ РЬЕП (&C)",          ID_VIEW_CAMERA_TO
        MENUITEM "NavigationMesh КИБт",           ID_VIEW_NAVIGATION_MESH
    END
    POPUP "ЕЕПђИЛ(&H)"
    BEGIN
        MENUITEM "LevelEdit СЄКИ(&A)...",         ID_APP_ABOUT
    END
END


