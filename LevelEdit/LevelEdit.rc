/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "File(F)"
    BEGIN
        MENUITEM "Open...\tCtrl+O(&O)",         ID_FILE_OPEN
        MENUITEM "Save\tCtrl+S(&S)",            ID_FILE_SAVE
        MENUITEM SEPARATOR
        MENUITEM "Exit(&X)",                    ID_APP_EXIT
    END
    POPUP "Mouse(&M)"
    BEGIN
        MENUITEM "None(&N)",                    ID_VIEW_CURNONE
        MENUITEM "Select(&C)",                  ID_VIEW_SELECT
        MENUITEM "Move(&M)",                    ID_VIEW_MOVE
        MENUITEM "Rotation(&R)",                ID_VIEW_ROTATE
        MENUITEM "Size(&S)",                    ID_VIEW_SCALE
        MENUITEM "Edit Box(&B)",                ID_VIEW_BOXEDIT
        MENUITEM "Select Mob Schedule(&K)",     ID_VIEW_SELECT_MOBSCH
    END
    POPUP "View(&V)"
    BEGIN
        MENUITEM "Tool Bar(&T)",                ID_VIEW_TOOLBAR
        MENUITEM "Status Bar(&S)",              ID_VIEW_STATUS_BAR
        MENUITEM "Fix camera to character(&H)", ID_VIEW_CAMERA_CHAR
        MENUITEM "Move character to select position(&C)", ID_VIEW_CAMERA_TO
    END
    POPUP "Help(&H)"
    BEGIN
        MENUITEM "LevelEdit Info.(&A)...",      ID_APP_ABOUT
    END
END


